generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model BattleReplay {
  id              String   @id @default(cuid())
  version         Int      @default(1)
  seed            String   @unique
  battleId        String
  winnerTeamId    String
  loserTeamId     String
  fighterIds      String[]
  setup           Json
  plan            Json
  replayCreatedAt DateTime
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([battleId])
}
